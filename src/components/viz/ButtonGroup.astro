---
// Row of snap-to buttons (e.g. "jump to vertex" controls). Clicking a
// button fires a `buttongroup:select` CustomEvent on the group element
// (detail: { value }) and toggles `aria-pressed`/`is-active` on the
// buttons — wire viz components to that event rather than individual
// button clicks.
interface Option {
  label: string;
  value: string;
}

interface Props {
  id: string;
  options: Option[];
}

const { id, options } = Astro.props;
---

<div class="button-group" id={id} role="group">
  {options.map((option, index) => (
    <button
      type="button"
      class="button-group__btn"
      data-value={option.value}
      aria-pressed={index === 0 ? 'true' : 'false'}
    >
      {option.label}
    </button>
  ))}
</div>

<style>
  .button-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-block: var(--space-3);
    font-family: var(--font-sans);
  }

  .button-group__btn {
    font-family: inherit;
    font-size: 0.85rem;
    background: var(--color-bg-recessed);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    padding: 0.35em 0.9em;
    cursor: pointer;
    color: var(--color-text);
  }

  .button-group__btn:hover { border-color: var(--color-link); }

  .button-group__btn[aria-pressed='true'] {
    background: var(--color-crimson);
    border-color: var(--color-crimson);
    color: var(--color-parchment);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.button-group').forEach((group) => {
    if (group.dataset.buttonGroupBound) return;
    group.dataset.buttonGroupBound = 'true';

    group.querySelectorAll<HTMLButtonElement>('.button-group__btn').forEach((button) => {
      button.addEventListener('click', () => {
        group
          .querySelectorAll<HTMLButtonElement>('.button-group__btn')
          .forEach((btn) => btn.setAttribute('aria-pressed', 'false'));
        button.setAttribute('aria-pressed', 'true');
        group.dispatchEvent(
          new CustomEvent('buttongroup:select', { detail: { value: button.dataset.value } })
        );
      });
    });
  });
</script>
