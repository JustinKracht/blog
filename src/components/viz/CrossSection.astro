---
// 2D cross-section: fix r23 = c and show the feasible (r12, r13) region as
// an ellipse (closed form in src/lib/correlation3.ts). Cheap, dependency-
// free SVG + vanilla JS — no three.js needed for this one.
import Slider from './Slider.astro';
---

<div class="cross-section">
  <svg
    id="cross-section-svg"
    viewBox="0 0 320 320"
    role="img"
    aria-label="The feasible region for r12 and r13 given a fixed r23, shown as an ellipse inside the square [-1,1] by [-1,1]"
  >
    <rect x="20" y="20" width="280" height="280" fill="none" stroke="var(--color-hairline)" />
    <line x1="160" y1="20" x2="160" y2="300" stroke="var(--color-hairline)" stroke-dasharray="2 3" />
    <line x1="20" y1="160" x2="300" y2="160" stroke="var(--color-hairline)" stroke-dasharray="2 3" />
    <text x="304" y="164" font-size="11" fill="var(--color-text)">r₁₂</text>
    <text x="164" y="16" font-size="11" fill="var(--color-text)">r₁₃</text>
    <ellipse id="cross-section-ellipse" cx="160" cy="160" rx="140" ry="140" fill="var(--color-fig-secondary)" fill-opacity="0.18" stroke="var(--color-fig-secondary)" stroke-width="2" />
  </svg>
  <Slider id="cross-section-r23" label="Fixed r₂₃" min={-0.98} max={0.98} step={0.02} value={0} />
</div>

<style>
  .cross-section {
    max-width: 360px;
    margin-inline: auto;
  }
  #cross-section-svg {
    width: 100%;
    height: auto;
    background: var(--color-bg-raised);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
  }
</style>

<script>
  import { crossSectionSemiAxes } from '../../lib/correlation3';

  const ellipse = document.getElementById('cross-section-ellipse');
  const slider = document.getElementById('cross-section-r23') as HTMLInputElement | null;
  if (!ellipse || !slider) {
    throw new Error('CrossSection: expected #cross-section-ellipse and #cross-section-r23');
  }

  // 280px square maps [-1,1] -> [20,300], so 1 unit = 140px.
  const SCALE = 140;

  function update() {
    const c = Number(slider!.value);
    const { u, v } = crossSectionSemiAxes(c);
    // The ellipse's axes are the +/-45deg directions in (r12,r13) space,
    // i.e. a 45deg rotation of an axis-aligned ellipse with radii u, v.
    ellipse!.setAttribute('rx', String(u * SCALE));
    ellipse!.setAttribute('ry', String(v * SCALE));
    ellipse!.setAttribute('transform', 'rotate(-45 160 160)');
  }

  slider.addEventListener('input', update);
  update();
</script>
