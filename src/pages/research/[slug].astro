---
import { getCollection, render } from 'astro:content';
import ExplainerLayout from '../../layouts/ExplainerLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('research', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ExplainerLayout title={entry.data.title} description={entry.data.description} part={entry.data.part} slug={entry.id}>
  <Content />
</ExplainerLayout>
