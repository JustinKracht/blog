---
import { getReferences, formatFullCitation, toBibtex } from '../../lib/bib';

interface Props {
  keys?: string[];
}

const { keys } = Astro.props;
const refs = getReferences().filter((ref) => !keys || keys.includes(ref.key));
---

<section class="bibliography" aria-label="References">
  <h2>References</h2>
  <ol class="bibliography__list">
    {refs.map((ref) => (
      <li id={`ref-${ref.key}`}>
        <p class="bibliography__citation">
          {formatFullCitation(ref)}
          {ref.doi && (
            <>
              {' '}
              <a href={`https://doi.org/${ref.doi}`} target="_blank" rel="noopener noreferrer">
                doi:{ref.doi}
              </a>
            </>
          )}
        </p>
        <button type="button" class="bibliography__copy" data-bibtex={toBibtex(ref)}>
          Copy BibTeX
        </button>
      </li>
    ))}
  </ol>
</section>

<style>
  .bibliography {
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-rule);
  }

  .bibliography__list {
    list-style: decimal;
    padding-left: 1.3em;
  }

  .bibliography__list li {
    margin-bottom: var(--space-3);
  }

  .bibliography__citation {
    font-size: 0.95rem;
  }

  .bibliography__copy {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    background: var(--color-bg-recessed);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    padding: 0.2em 0.6em;
    margin-top: var(--space-1);
    cursor: pointer;
    color: var(--color-text);
  }
  .bibliography__copy:hover { border-color: var(--color-link); color: var(--color-link); }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.bibliography__copy').forEach((button) => {
    button.addEventListener('click', async () => {
      const bibtex = button.dataset.bibtex ?? '';
      try {
        await navigator.clipboard.writeText(bibtex);
        const original = button.textContent;
        button.textContent = 'Copied!';
        setTimeout(() => {
          button.textContent = original;
        }, 1500);
      } catch {
        // Clipboard API unavailable (e.g. insecure context) — no-op.
      }
    });
  });
</script>
