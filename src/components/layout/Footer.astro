---
import { SOCIAL_LINKS, withBase } from '../../lib/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrapper site-footer__inner">
    <p class="site-footer__copy">&copy; {year} Justin Kracht</p>
    <ul class="site-footer__links">
      {SOCIAL_LINKS.map((link) => (
        <li>
          <a href={link.href} rel="me noopener noreferrer" target="_blank">{link.label}</a>
        </li>
      ))}
      <li><a href={withBase('rss.xml')}>RSS</a></li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    margin-top: var(--space-7);
    padding-block: var(--space-4);
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    justify-content: space-between;
  }

  .site-footer__copy { opacity: 0.75; }

  .site-footer__links {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-footer__links a {
    color: var(--color-text);
    text-decoration: none;
  }
  .site-footer__links a:hover { color: var(--color-link); }
</style>
