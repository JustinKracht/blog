---
// Component-library reference page: exercises every Phase 2 explainer
// primitive in one place. Not real content — excluded from the research
// index (it's not in the content collection) and from the sitemap (see
// astro.config.mjs). Keep this in sync as new primitives are added.
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import ExplainerLayout from '../../layouts/ExplainerLayout.astro';
import Figure from '../../components/viz/Figure.astro';
import Sidenote from '../../components/viz/Sidenote.astro';
import Citation from '../../components/viz/Citation.astro';
import Bibliography from '../../components/viz/Bibliography.astro';
import Scrolly from '../../components/viz/Scrolly.astro';
import ScrollyStep from '../../components/viz/ScrollyStep.astro';
import Slider from '../../components/viz/Slider.astro';
import ButtonGroup from '../../components/viz/ButtonGroup.astro';

interface Row {
  rho: number;
  eigenvalues: [number, number, number];
}

const dataPath = join(process.cwd(), 'public/data/example-eigenvalues.json');
const rows: Row[] = JSON.parse(readFileSync(dataPath, 'utf-8'));

const width = 640;
const height = 320;
const margin = { top: 20, right: 20, bottom: 36, left: 44 };
const innerW = width - margin.left - margin.right;
const innerH = height - margin.top - margin.bottom;
const rhoMin = -0.45;
const rhoMax = 0.99;
const valMax = 2;

const xScale = (rho: number) => margin.left + ((rho - rhoMin) / (rhoMax - rhoMin)) * innerW;
const yScale = (value: number) => margin.top + innerH - (value / valMax) * innerH;

const majorPath = rows
  .map((row, i) => `${i === 0 ? 'M' : 'L'} ${xScale(row.rho).toFixed(1)} ${yScale(row.eigenvalues[0]).toFixed(1)}`)
  .join(' ');
const minorPath = rows
  .map((row, i) => `${i === 0 ? 'M' : 'L'} ${xScale(row.rho).toFixed(1)} ${yScale(row.eigenvalues[2]).toFixed(1)}`)
  .join(' ');

const vertexOptions = [
  { label: 'ρ = -0.45', value: '-0.45' },
  { label: 'ρ = 0', value: '0' },
  { label: 'ρ = 0.99', value: '0.99' },
];
---

<ExplainerLayout
  title="Component library reference"
  description="A demo page exercising every Phase 2 explainer primitive: figures, sidenotes, citations, scrolly steps, sliders, and button groups."
  slug="demo"
>
  <p>
    This page exists to exercise the explainer component library end to end, not to
    explain anything<Sidenote>
      It reuses the eigenvalue data generated by <code>data-gen/example.R</code> — see
      the eigenvalue-vs-ρ chart below — purely because that data already existed
      from the Phase&nbsp;2 data-gen skeleton, not because equicorrelation matrices are
      the point here
    </Sidenote>. Every control below is wired to the same static chart so you can see
    the primitives actually do something, the way <Citation citeKey="rousseeuw1994" /> would
    be cited in real explainer prose, with a full reference in the bibliography at the
    bottom of the page.
  </p>

  <Figure wide caption="Eigenvalues of the 3×3 equicorrelation matrix R = (1 − ρ)I + ρJ, computed in R and rendered as a static SVG at build time.">
    <svg id="demo-chart" viewBox={`0 0 ${width} ${height}`} role="img" aria-label="Eigenvalues as a function of rho">
      <line x1={margin.left} y1={margin.top} x2={margin.left} y2={height - margin.bottom} stroke="var(--color-hairline)" />
      <line x1={margin.left} y1={height - margin.bottom} x2={width - margin.right} y2={height - margin.bottom} stroke="var(--color-hairline)" />
      <text x={margin.left} y={16} font-size="12" fill="var(--color-text)">eigenvalue</text>
      <text x={width - margin.right} y={height - 8} font-size="12" text-anchor="end" fill="var(--color-text)">ρ →</text>
      <path id="curve-major" d={majorPath} fill="none" stroke="var(--color-fig-primary)" stroke-width="2" />
      <path id="curve-minor" d={minorPath} fill="none" stroke="var(--color-fig-secondary)" stroke-width="2" />
      <circle id="demo-marker" cx={xScale(0)} cy={yScale(1)} r="5" fill="var(--color-fig-tertiary)" />
    </svg>
  </Figure>

  <h2>Slider control</h2>
  <p>Drag to move the marker along ρ; the readout and marker position both update.</p>
  <Slider id="demo-rho" label="ρ" min={-0.45} max={0.99} step={0.03} value={0} />

  <h2>Button group (snap-to)</h2>
  <ButtonGroup id="demo-vertices" options={vertexOptions} />

  <h2>Scrolly steps</h2>
  <Scrolly>
    <Fragment slot="graphic">
      <p class="demo-scrolly-readout">
        Active step: <output id="demo-scrolly-output">0</output>
      </p>
    </Fragment>
    <Fragment slot="steps">
      <ScrollyStep>Step 0: the large eigenvalue, 1 + 2ρ, highlighted in crimson.</ScrollyStep>
      <ScrollyStep>Step 1: the repeated small eigenvalue, 1 − ρ, highlighted in petrol.</ScrollyStep>
      <ScrollyStep>Step 2: both curves shown at full strength — the boundary case.</ScrollyStep>
    </Fragment>
  </Scrolly>

  <Bibliography keys={['rousseeuw1994', 'example2024']} />
</ExplainerLayout>

<style>
  #demo-chart {
    width: 100%;
    height: auto;
    background: var(--color-bg-raised);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
  }

  .demo-scrolly-readout {
    font-family: var(--font-mono);
    font-size: 1.1rem;
  }
</style>

<script>
  import { withBase } from '../../lib/site';

  const rows = await fetch(withBase('data/example-eigenvalues.json')).then((r) => r.json());

  const marker = document.getElementById('demo-marker');
  const slider = document.getElementById('demo-rho') as HTMLInputElement | null;

  const rhoMin = -0.45;
  const rhoMax = 0.99;
  const valMax = 2;
  const width = 640;
  const height = 320;
  const margin = { top: 20, right: 20, bottom: 36, left: 44 };
  const innerW = width - margin.left - margin.right;
  const innerH = height - margin.top - margin.bottom;
  const xScale = (rho: number) => margin.left + ((rho - rhoMin) / (rhoMax - rhoMin)) * innerW;
  const yScale = (value: number) => margin.top + innerH - (value / valMax) * innerH;

  function nearestRow(rho: number) {
    return rows.reduce((best: any, row: any) =>
      Math.abs(row.rho - rho) < Math.abs(best.rho - rho) ? row : best
    );
  }

  function moveMarker(rho: number) {
    const row = nearestRow(rho);
    marker?.setAttribute('cx', String(xScale(row.rho)));
    marker?.setAttribute('cy', String(yScale(row.eigenvalues[0])));
  }

  slider?.addEventListener('input', () => moveMarker(Number(slider.value)));

  const buttonGroup = document.getElementById('demo-vertices');
  buttonGroup?.addEventListener('buttongroup:select', (event) => {
    const { value } = (event as CustomEvent).detail;
    moveMarker(Number(value));
    if (slider) slider.value = value;
    const output = document.getElementById('demo-rho-output');
    if (output) output.textContent = `${value}`;
  });

  const scrolly = document.querySelector('.scrolly');
  const scrollyOutput = document.getElementById('demo-scrolly-output');
  const curveMajor = document.getElementById('curve-major');
  const curveMinor = document.getElementById('curve-minor');
  scrolly?.addEventListener('scrolly:step', (event) => {
    const { index } = (event as CustomEvent).detail;
    if (scrollyOutput) scrollyOutput.textContent = String(index);
    curveMajor?.setAttribute('stroke-width', index === 0 || index === 2 ? '4' : '2');
    curveMinor?.setAttribute('stroke-width', index === 1 || index === 2 ? '4' : '2');
  });
</script>
